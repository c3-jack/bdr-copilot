# BDR Copilot Configuration
# Copy this file to .env and fill in your values

# Claude API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Tavily API Key for web search (get from tavily.com)
TAVILY_API_KEY=tvly-xxxxx

# ZoomInfo API credentials (optional — enables contact/company enrichment)
ZOOMINFO_CLIENT_ID=your-client-id
ZOOMINFO_PRIVATE_KEY=your-private-key

# Dynamics 365 Environment URL (optional — enables Pipeline view)
DYNAMICS_URL=https://c3ai.crm.dynamics.com

# Server port
PORT=3001
