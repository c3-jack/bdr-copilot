# BDR Copilot Configuration
# Most credentials are configured via the Settings page in the app.
# These env vars are optional fallbacks.

# ZoomInfo API credentials (optional — enables contact/company enrichment)
ZOOMINFO_CLIENT_ID=your-client-id
ZOOMINFO_PRIVATE_KEY=your-private-key

# Dynamics 365 credentials (optional — enables Pipeline view)
DYNAMICS_ORG_URL=https://yourorg.crm.dynamics.com
DYNAMICS_TENANT_ID=your-tenant-id
DYNAMICS_CLIENT_ID=your-client-id
DYNAMICS_CLIENT_SECRET=your-client-secret

# Server port
PORT=3001
